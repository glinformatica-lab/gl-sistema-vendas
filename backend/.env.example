# Copie este arquivo para .env e preencha os valores
# (em produção no Render, configure essas mesmas variáveis no painel)

# Conexão PostgreSQL (no Render, copie da página do banco)
# Local: postgres://postgres:senha@localhost:5432/sistema_vendas
DATABASE_URL=postgres://postgres:senha@localhost:5432/sistema_vendas

# Segredo para assinar o JWT (gere uma string aleatória de 32+ caracteres)
JWT_SECRET=troque-isso-por-uma-string-aleatoria-bem-longa

# Porta (Render define automaticamente — não precisa em produção)
PORT=3000

# Em produção (Render), defina como production
NODE_ENV=development
